# TradeWatch — environment variables
# Copy this file to .env and fill in your values
# .env is listed in .gitignore and will NOT be committed to GitHub

# Flask session secret — change this to a random string in production
SECRET_KEY=change-me-to-a-random-string

# Optional: pre-load your Claude API key so you skip the UI entry step
# Leave blank to use the in-app key entry screen
# CLAUDE_API_KEY=sk-ant-api03-...
