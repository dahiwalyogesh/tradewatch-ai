  "name": "TradeWatch",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu",
  "forwardPorts": [8080],
  "postCreateCommand": "echo 'TradeWatch ready! Run: python3 -m http.server 8080'",
  "customizations": {
    "vscode": {
      "extensions": ["ritwickdey.LiveServer"],
      "settings": {
        "liveServer.settings.port": 8080
      }
    }
  }
}
